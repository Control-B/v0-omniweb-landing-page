# ── Omniweb Engine (required) ─────────────────────────────────────────
OMNIWEB_ORCHESTRATOR_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
FASTAPI_ASSISTANT_URL=https://omniweb-engine-rs6fr.ondigitalocean.app

# ── LiveKit (optional — for voice testing) ─────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Shopify (optional) ─────────────────────────────────────────────────
NEXT_PUBLIC_SHOPIFY_APP_URL=https://shopify.omniweb.ai

# ── Misc ───────────────────────────────────────────────────────────────
OMNIWEB_PUBLIC_TENANT_SLUG=
LIVEKIT_AGENT_NAME=
NEXT_PUBLIC_VOICE_TRANSPORT=livekit
NEXT_PUBLIC_CDN_ORIGIN=https://cdn.omniweb.ai
