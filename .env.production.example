# ── Clerk (required) — MUST be the same Clerk application as the Omniweb engine / dashboard
# so session tokens verify on POST {ENGINE}/api/auth/clerk-session
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding
DATABASE_URL=
NEXT_PUBLIC_APP_URL=https://omniweb.ai

# ── Omniweb Engine (FastAPI) — public + server-side (required) ───────
# Use the same base URL the engine is deployed at (e.g. DO app or https://api.omniweb.ai)
NEXT_PUBLIC_OMNIWEB_ENGINE_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
OMNIWEB_ENGINE_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
OMNIWEB_ORCHESTRATOR_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
FASTAPI_ASSISTANT_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
NEXT_PUBLIC_LANDING_PAGE_CLIENT_ID=

# ── LiveKit (optional — for voice testing) ─────────────────────────────
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Shopify (optional) ─────────────────────────────────────────────────
NEXT_PUBLIC_SHOPIFY_APP_URL=https://shopify.omniweb.ai
SHOPIFY_APP_PUBLIC_URL=https://shopify.omniweb.ai

# ── Misc ───────────────────────────────────────────────────────────────
OMNIWEB_PUBLIC_TENANT_SLUG=
LIVEKIT_AGENT_NAME=
NEXT_PUBLIC_VOICE_TRANSPORT=livekit
NEXT_PUBLIC_CDN_ORIGIN=https://cdn.omniweb.ai
