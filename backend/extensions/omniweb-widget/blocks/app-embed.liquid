{% comment %}
  Omniweb — AI Shopping Assistant
  ─────────────────────────────────────
  This app embed block injects the Omniweb chat widget on every storefront page.

  To activate:
    Shopify Admin → Online Store → Themes → Customize →
    App Embeds → toggle "Omniweb Widget" on → Save
{% endcomment %}

{% assign omniweb_engine_url = block.settings.api_url | default: 'https://omniweb-engine-rs6fr.ondigitalocean.app' %}
<script
  src="{{ omniweb_engine_url }}/static/omniweb-shopify-widget.js"
  data-engine="{{ omniweb_engine_url }}"
  data-shop="{{ shop.permanent_domain }}"
  defer
></script>

{% schema %}
{
  "name": "Omniweb Widget",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "Paste your **Omniweb Engine URL** below then save. The AI shopping assistant will appear on all storefront pages."
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL",
      "default": "https://omniweb-engine-rs6fr.ondigitalocean.app",
      "info": "Use your DigitalOcean Omniweb Engine URL, for example https://api.omniweb.ai"
    }
  ]
}
{% endschema %}
