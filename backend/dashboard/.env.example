# Omniweb Agent Engine (FastAPI) — required for admin API + widget.
# In production, point this to the engine host if the dashboard runs on a different origin.
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
# NEXT_PUBLIC_ENGINE_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
# NEXT_PUBLIC_API_URL=http://localhost:8000
# Clerk (same pk as FastAPI `CLERK_PUBLISHABLE_KEY` in repo root `.env`).
# Either name works; if you only set `CLERK_PUBLISHABLE_KEY` in `../.env`, next.config maps it.
CLERK_PUBLISHABLE_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
