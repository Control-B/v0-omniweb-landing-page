<section class="hero-media" aria-label="{{ section.settings.heading | escape }}">
  <div class="hero-media__media">
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1800x' }}
    {% elsif section.settings.image != blank %}
      {% render 'responsive-image', image: section.settings.image, sizes: '100vw', loading: 'eager', alt: section.settings.heading %}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>
  <div class="page-width">
    <div class="hero-media__content">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1 class="display">{{ section.settings.heading }}</h1>
      {% if section.settings.text != blank %}
        <p class="subheading" style="color: rgba(255,255,255,.82);">{{ section.settings.text }}</p>
      {% endif %}
      <div class="hero-media__actions">
        {% if section.settings.primary_label != blank %}
          <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {% endif %}
        {% if section.settings.secondary_label != blank %}
          <a class="button button--secondary" style="border-color: rgba(255,255,255,.7); color: #fff;" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Fullscreen hero media",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Presence AI" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A storefront that sells with video, context, and AI." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Launch a premium editorial shopping experience with AI-ready selling zones and shoppable video built into every key journey." },
    { "type": "image_picker", "id": "image", "label": "Fallback image" },
    { "type": "video", "id": "video", "label": "Hero video" },
    { "type": "text", "id": "primary_label", "label": "Primary CTA", "default": "Shop the edit" },
    { "type": "url", "id": "primary_link", "label": "Primary link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary CTA", "default": "Ask the AI assistant" },
    { "type": "url", "id": "secondary_link", "label": "Secondary link" }
  ],
  "presets": [{ "name": "Fullscreen hero media" }]
}
{% endschema %}
