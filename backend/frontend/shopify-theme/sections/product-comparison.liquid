<section class="section">
  <div class="page-width">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="heading">{{ section.settings.heading }}</h2>
    <div class="grid grid--3" style="margin-top: 1.5rem;">
      {% for block in section.blocks %}
        <div class="card" style="padding: 1.25rem;" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.title }}</h3>
          <p class="subheading">{{ block.settings.text }}</p>
          <strong>{{ block.settings.best_for }}</strong>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product comparison",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Compare" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Help shoppers choose with confidence" }
  ],
  "blocks": [
    { "type": "column", "name": "Comparison column", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Essential" },
      { "type": "textarea", "id": "text", "label": "Text", "default": "Core features and benefits." },
      { "type": "text", "id": "best_for", "label": "Best for", "default": "Best for first-time buyers" }
    ] }
  ],
  "presets": [{ "name": "Product comparison", "blocks": [{ "type": "column" }, { "type": "column" }, { "type": "column" }] }]
}
{% endschema %}
