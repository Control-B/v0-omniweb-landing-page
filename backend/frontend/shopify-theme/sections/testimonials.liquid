<section class="section">
  <div class="page-width">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="heading">{{ section.settings.heading }}</h2>
    <div class="grid grid--3" style="margin-top: 1.5rem;">
      {% for block in section.blocks %}
        <blockquote class="card" style="padding: 1.25rem;" {{ block.shopify_attributes }}>
          <p>“{{ block.settings.quote }}”</p>
          <footer style="color: var(--color-muted);">— {{ block.settings.author }}</footer>
        </blockquote>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Social proof" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Loved by thoughtful shoppers" }
  ],
  "blocks": [
    { "type": "quote", "name": "Quote", "settings": [
      { "type": "textarea", "id": "quote", "label": "Quote", "default": "The assistant helped me choose in minutes." },
      { "type": "text", "id": "author", "label": "Author", "default": "Presence customer" }
    ] }
  ],
  "presets": [{ "name": "Testimonials", "blocks": [{ "type": "quote" }, { "type": "quote" }, { "type": "quote" }] }]
}
{% endschema %}
