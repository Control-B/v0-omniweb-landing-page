<section class="section section--tight">
  <div class="page-width">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="heading">{{ section.settings.heading }}</h2>
    <div class="grid grid--4" style="margin-top: 1.5rem;">
      {% for block in section.blocks %}
        <a class="card" href="{{ block.settings.link }}" style="position: relative; aspect-ratio: 4 / 5;" {{ block.shopify_attributes }}>
          {% render 'responsive-image', image: block.settings.image, sizes: '25vw', alt: block.settings.title %}
          <span style="position: absolute; inset-inline: 1rem; bottom: 1rem; background: var(--color-surface); border-radius: 999px; padding: .65rem .9rem; font-weight: 800;">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product category cards",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by need" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Choose your path" }
  ],
  "blocks": [
    { "type": "category", "name": "Category", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "title", "label": "Title", "default": "New arrivals" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "presets": [{ "name": "Product category cards", "blocks": [{ "type": "category" }, { "type": "category" }, { "type": "category" }, { "type": "category" }] }]
}
{% endschema %}
