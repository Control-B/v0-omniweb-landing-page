<section class="section">
  <div class="page-width">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="heading">{{ section.settings.heading }}</h2>
    <div class="grid grid--3" style="margin-top: 1.5rem;">
      {% for block in section.blocks %}
        <a class="card" href="{{ block.settings.link }}" style="aspect-ratio: {% cycle '4 / 5', '1 / 1', '3 / 4' %}; position: relative;" {{ block.shopify_attributes }}>
          {% render 'responsive-image', image: block.settings.image, sizes: '33vw', alt: block.settings.title %}
          <span style="position: absolute; left: 1rem; bottom: 1rem; background: var(--color-surface); padding: .6rem .85rem; border-radius: 999px; font-weight: 700;">{{ block.settings.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lookbook grid",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Lookbook" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Editorial shopping moments" }
  ],
  "blocks": [
    { "type": "tile", "name": "Tile", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "title", "label": "Title", "default": "The edit" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "presets": [{ "name": "Lookbook grid", "blocks": [{ "type": "tile" }, { "type": "tile" }, { "type": "tile" }] }]
}
{% endschema %}
