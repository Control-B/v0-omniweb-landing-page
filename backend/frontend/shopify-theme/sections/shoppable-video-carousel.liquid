<section class="section">
  <div class="page-width">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="heading" style="margin-bottom: 1.5rem;">{{ section.settings.heading }}</h2>
    <div class="horizontal-scroll" aria-label="Shoppable videos">
      {% for block in section.blocks %}
        <article class="video-card" {{ block.shopify_attributes }}>
          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: autoplay: false, loop: true, muted: true, controls: true, image_size: '720x' }}
          {% elsif block.settings.image != blank %}
            {% render 'responsive-image', image: block.settings.image, sizes: '360px', alt: block.settings.title %}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          <div class="video-card__caption">
            <h3>{{ block.settings.title }}</h3>
            {% if block.settings.link != blank %}
              <a class="button button--accent" href="{{ block.settings.link }}">{{ block.settings.cta }}</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shoppable video carousel",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Watch and shop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "See the story in motion" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video card",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "image", "label": "Fallback image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Product story" },
        { "type": "text", "id": "cta", "label": "CTA", "default": "Shop now" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable video carousel",
      "blocks": [{ "type": "video" }, { "type": "video" }, { "type": "video" }]
    }
  ]
}
{% endschema %}
