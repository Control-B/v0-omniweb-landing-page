{% if section.settings.text != blank %}
  <div class="announcement" role="region" aria-label="Announcement">
    {{ section.settings.text }}
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping over $100. Ask our AI stylist for help choosing."
    }
  ]
}
{% endschema %}
