<section class="section">
  <div class="page-width">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="heading">{{ section.settings.heading }}</h1>
    <p class="subheading">{{ section.settings.text }}</p>
    <div class="grid grid--3" style="margin-top: 1.5rem;">
      {% for block in section.blocks %}
        <article class="video-card" {{ block.shopify_attributes }}>
          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: controls: true, muted: true, image_size: '900x', loading: 'lazy' }}
          {% else %}
            {% render 'responsive-image', image: block.settings.image, sizes: '33vw', alt: block.settings.title %}
          {% endif %}
          <div class="video-card__caption"><h3>{{ block.settings.title }}</h3></div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video showroom",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Video showroom" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop through motion" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Create an immersive video catalog for product demos, founder stories, lookbooks, and tutorials." }
  ],
  "blocks": [
    { "type": "video", "name": "Video", "settings": [
      { "type": "video", "id": "video", "label": "Video" },
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "title", "label": "Title", "default": "Showroom story" }
    ] }
  ],
  "presets": [{ "name": "Video showroom", "blocks": [{ "type": "video" }, { "type": "video" }, { "type": "video" }] }]
}
{% endschema %}
