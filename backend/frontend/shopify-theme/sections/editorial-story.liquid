<section class="section">
  <div class="page-width grid grid--2" style="align-items: center;">
    <div>
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="heading">{{ section.settings.heading }}</h2>
      <p class="subheading">{{ section.settings.text }}</p>
      {% if section.settings.cta_label != blank %}
        <a class="button" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>
    <div class="card" style="aspect-ratio: 4 / 5;">
      {% render 'responsive-image', image: section.settings.image, sizes: '(min-width: 990px) 50vw, 100vw', alt: section.settings.heading %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Editorial brand story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Made with intention" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Editorial storytelling for modern product brands." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Use this section to blend founder story, product education, and guided shopping prompts into one premium brand moment." },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read the story" },
    { "type": "url", "id": "cta_link", "label": "CTA link" }
  ],
  "presets": [{ "name": "Editorial brand story" }]
}
{% endschema %}
