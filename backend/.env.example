# ══════════════════════════════════════════════════════════════════════════════
# Omniweb Agent Engine v2 — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# ── ElevenLabs (Voice + Text AI Engine) ───────────────────────────────────────
# Get your API key at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL   # Rachel / preferred female default voice for realtime TTS
# Webhook secret — set in ElevenLabs dashboard → Agent → Platform Settings
ELEVENLABS_WEBHOOK_SECRET=

# ── Twilio (Phone Numbers + SMS) ──────────────────────────────────────────────
# Buy numbers from Twilio, import into ElevenLabs for voice.
# Twilio also handles all SMS sending.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ── Retell AI (Web Calls + AI Telephony) ──────────────────────────────────────
# Get your API key from the Retell dashboard.
RETELL_API_KEY=key_...
# Default agent used for anonymous/landing-page web calls.
RETELL_LANDING_AGENT_ID=agent_...
# Optional shared secret for Retell webhook verification when configured.
RETELL_WEBHOOK_SECRET=

# ── OpenAI (Post-call LLM Processing) ────────────────────────────────────────
# Used for lead extraction from transcripts (NOT for the voice agent itself)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://omniweb:password@localhost:5432/omniweb_engine

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Stripe (Billing) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App Security ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-strong-random-secret
INTERNAL_API_KEY=change-me-use-a-strong-random-secret

# ── App Settings ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_BASE_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
ENGINE_BASE_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
# Dashboard + /landing + /widget: use the App Platform default URL (omniweb.ai is the public marketing site, not this app).
PLATFORM_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Shopify (Commerce Assistant App) ───────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://omniweb-engine-rs6fr.ondigitalocean.app
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2026-07
SHOPIFY_SCOPES=read_products,read_discounts,write_discounts,read_orders,read_customers,read_themes,write_script_tags,unauthenticated_read_product_listings
SHOPIFY_ENGINE_SHARED_SECRET=change-me-use-a-strong-random-secret
OMNIWEB_ENGINE_SHARED_SECRET=change-me-use-the-same-value-as-shopify-engine-secret
