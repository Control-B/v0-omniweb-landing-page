#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-origin}"
remote_url="$(git remote get-url "$remote_name" 2>/dev/null || true)"
expected_repo="Control-B/v0-omniweb-landing-page"

if [[ -z "$remote_url" ]]; then
  echo "[pre-push] Could not resolve remote URL for '$remote_name'. Blocking push."
  exit 1
fi

if [[ "$remote_url" != *"$expected_repo"* ]]; then
  echo "[pre-push] Blocked push: remote '$remote_name' is '$remote_url'"
  echo "[pre-push] Expected repository containing: '$expected_repo'"
  exit 1
fi

exit 0
